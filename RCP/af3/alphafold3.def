Bootstrap: docker
From: nvidia/cuda:12.6.3-base-ubuntu24.04

%labels
    Author AlphaFold3 Apptainer Build
    Version 3.0
    Description AlphaFold3 - inference only, no MSA/template pipeline, no HMMER

%environment
    export PATH="/alphafold3_venv/bin:/root/.local/bin:$PATH"
    export XLA_FLAGS="--xla_gpu_enable_triton_gemm=false"
    export XLA_PYTHON_CLIENT_PREALLOCATE=false
    export TF_FORCE_UNIFIED_MEMORY=1
    export XLA_CLIENT_MEM_FRACTION=1.5
    export UV_PROJECT_ENVIRONMENT=/alphafold3_venv
    # Prevent uv from touching the read-only venv at runtime
    export UV_NO_SYNC=1
    export UV_COMPILE_BYTECODE=0

%post
    export DEBIAN_FRONTEND=noninteractive
    export UV_PROJECT_ENVIRONMENT=/alphafold3_venv

    # --- System dependencies ---
    apt-get update --quiet
    apt-get install --yes --quiet \
        curl \
        python3.12 python3.12-dev \
        git wget gcc g++ make zlib1g-dev zstd

    # --- Install uv (pinned version) ---
    curl -LsSf https://astral.sh/uv/0.9.24/install.sh | sh
    export PATH="/root/.local/bin:$PATH"

    # --- Create virtualenv ---
    uv venv $UV_PROJECT_ENVIRONMENT
    export PATH="$UV_PROJECT_ENVIRONMENT/bin:$PATH"

    # --- AlphaFold3 Python deps ---
    cd /app/alphafold
    UV_LINK_MODE=copy uv sync --frozen --all-groups --no-editable

    # --- Build chemical components database ---
    uv run build_data

    # --- Cleanup ---
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%files
    . /app/alphafold

%runscript
    exec python3 /app/alphafold/run_alphafold.py "$@"

%help
    AlphaFold 3 - inference-only, de novo design.
    No MSA, no templates, no HMMER required.

    Example run:
      apptainer run --nv \
        --bind /path/to/weights:/models \
        --bind /path/to/inputs:/inputs \
        --bind /path/to/outputs:/outputs \
        alphafold3.sif \
          --json_path /inputs/design.json \
          --model_dir /models \
          --output_dir /outputs \
          --jax_compilation_cache_dir /outputs/jax_cache
