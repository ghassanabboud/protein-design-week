Bootstrap: docker
From: nvidia/cuda:11.8.0-runtime-ubuntu22.04

%post
    apt-get update && apt-get install -y \
        python3.10 \
        python3-pip \
        git \
        wget \
        && rm -rf /var/lib/apt/lists/*
    
    git clone https://github.com/LBM-EPFL/CARBonAra.git /app/CARBonAra
    cd /app/CARBonAra
    pip install --no-cache-dir .
    
    # Pre-download model weights
    python3 -c "from carbonara import CARBonAra; model = CARBonAra(device_name='cpu')"

%runscript
    exec carbonara "$@"

